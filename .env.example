# ── 법령 수집·적재 파이프라인 환경변수 ──
# 이 파일을 .env 로 복사해서 값을 채운다:  cp .env.example .env
# (.env 는 절대 커밋 금지 — .gitignore 에 이미 제외됨)

# ── 필수 ──
LAW_API_OC=발급받은_OC_키                 # 법제처 OpenAPI 인증키(open.law.go.kr 에서 발급)

# ── 접속 ──
DATABASE_URL=postgresql://lawuser:lawpass@localhost:5544/lawdb   # 적재 DB(lawdb)
TEMPORAL_ADDRESS=localhost:7233           # Temporal gRPC
TEMPORAL_NAMESPACE=default
LAW_TASK_QUEUE=law-pipeline

# ── 수집/적재 옵션 ──
LAW_CATALOG_LAW_ONLY=true                 # catalog 추적 단위: 법률만(true) / 시행령·규칙 포함 전체(false)
LAW_BACKFILL_BATCH=20                      # backfill 동시 수집 배치 크기(부하/히스토리 제어)
LAW_SYNC_CRON=0 3 * * *                    # 매일 자동 sync 스케줄(cron, 기본 03:00)

# ── 로컬 파일 저장 토글 ──
# 파이프라인은 DB 적재라 로컬 파일 불필요 → 운영 워커에선 raw off 권장
LAW_SAVE_RAW=true                          # search/body/위임 원본을 output/raw/ 에 저장
LAW_SAVE_PAYLOAD=false                     # 최종 payload 를 output/ 에 저장

# ── 알림(선택) ──
# 있으면 Slack 으로, 없으면 macOS 데스크톱 알림, 둘 다 안 되면 조용히 패스
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ── 검증(verify) ──
# 파이프라인 통합: 수집 후 자동 커버리지 검증 (Chrome ground-truth 대조, 최선 노력)
LAW_VERIFY_BACKFILL=random:3               # 초기적재 후: off | random:N | all
LAW_VERIFY_SYNC=changed                    # 동기 후:    off | changed | all
# 독립 실행(collector.verify) 기본값 (CLI 인자로 덮어씀)
LAW_VERIFY_MODE=random                     # random | all | changed
LAW_VERIFY_N=3                             # random 개수 / changed 일수
